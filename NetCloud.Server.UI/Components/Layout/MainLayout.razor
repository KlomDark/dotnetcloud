@inherits LayoutComponentBase
@inject DotNetCloud.Server.UI.Services.AuthService Auth
@inject NavigationManager Nav

<nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">NetCloud</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                @if (isLoggedIn)
                {
                    <li class="nav-item">
                        <button class="btn btn-primary nav-link" @onclick="Logout">Logout</button>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" href="/login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/register">Register</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<div class="container">
    @Body
</div>

<div id="blazor-error-ui" class="alert alert-danger position-fixed bottom-0 end-0 m-3 shadow" style="display:none;">
    <span>An unhandled error has occurred.</span>
    <a href="" class="reload alert-link">Reload</a>
    <button type="button" class="btn-close ms-2 dismiss" aria-label="Close"></button>
</div>

@code {
    private bool isLoggedIn;
    private bool canUseJsInterop;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            canUseJsInterop = true;
            var token = await Auth.GetTokenAsync(canUseJsInterop);
            isLoggedIn = !string.IsNullOrEmpty(token);
            StateHasChanged();
        }
    }

    private async Task Logout()
    {
        await Auth.LogoutAsync(canUseJsInterop);
        isLoggedIn = false;
        Nav.NavigateTo("/");
    }
}
