@page "/users"
@using System.Net.Http.Json
@using DotNetCloud.Core
@inject IHttpClientFactory HttpClientFactory
@inject ILogger<UserManagement> Logger

<h3>User Management</h3>

@if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (users == null)
{
    <p>Loading...</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>UserName</th>
                <th>Email</th>
                <th>Roles</th>
                <th>Assign Role</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in users)
            {
                <tr>
                    <td>@user.UserName</td>
                    <td>@user.Email</td>
                    <td>
                        @foreach (var role in user.Roles)
                        {
                            <span class="badge bg-primary">@role <button class="btn btn-sm btn-danger ms-1" @onclick="() => RemoveRole(user.Id, role)">x</button></span>
                        }
                    </td>
                    <td>
                        <select @bind="selectedRole[user.Id]">
                            <option value="">Select role</option>
                            @foreach (var role in Enum.GetValues<RoleType>())
                            {
                                <option value="@role">@role</option>
                            }
                        </select>
                        <button class="btn btn-sm btn-success ms-1" @onclick="() => AssignRole(user.Id)">Assign</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    class UserDto
    {
        public Guid Id { get; set; }
        public string UserName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public List<string> Roles { get; set; } = new();
    }
    class AssignRoleDto
    {
        public Guid UserId { get; set; }
        public Guid RoleId { get; set; }
    }

    List<UserDto>? users;
    Dictionary<Guid, RoleType?> selectedRole = new();
    string? errorMessage;
    HttpClient? Http;

    // Map RoleType to seeded GUIDs
    Dictionary<RoleType, Guid> roleGuids = new()
    {
        { RoleType.User, new Guid("1dfc789a-77e3-3e5a-a43e-738c3d7aeb6f") },
        { RoleType.TeamLeader, new Guid("3061b0e7-79fe-2c5b-8519-9c4e9ced0d7f") },
        { RoleType.Administrator, new Guid("f88b3b91-9830-4a5c-b338-1e1ea1e1efae") }
    };

    protected override async Task OnInitializedAsync()
    {
        Http = HttpClientFactory.CreateClient("Default");
        try
        {
            users = await Http.GetFromJsonAsync<List<UserDto>>("api/user");
            if (users != null)
            {
                foreach (var user in users)
                    selectedRole[user.Id] = null;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Initialization error: {ex.Message}";
            Logger.LogError(ex, "Error during UserManagement initialization");
        }
    }

    async Task AssignRole(Guid userId)
    {
        try
        {
            var role = selectedRole[userId];
            if (role == null) return;
            var dto = new AssignRoleDto { UserId = userId, RoleId = roleGuids[role.Value] };
            var resp = await Http!.PostAsJsonAsync("api/user/assign-role", dto);
            if (resp.IsSuccessStatusCode)
            {
                await RefreshUsers();
            }
            else
            {
                errorMessage = $"Failed to assign role: {resp.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"AssignRole error: {ex.Message}";
            Logger.LogError(ex, "Error assigning role");
        }
    }

    async Task RemoveRole(Guid userId, string role)
    {
        try
        {
            // Find GUID for role name
            var roleType = Enum.TryParse<RoleType>(role, out var rt) ? rt : (RoleType?)null;
            if (roleType == null) return;
            var dto = new AssignRoleDto { UserId = userId, RoleId = roleGuids[roleType.Value] };
            var resp = await Http!.PostAsJsonAsync("api/user/remove-role", dto);
            if (resp.IsSuccessStatusCode)
            {
                await RefreshUsers();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"RemoveRole error: {ex.Message}";
            Logger.LogError(ex, "Error removing role");
        }
    }

    async Task RefreshUsers()
    {
        try
        {
            users = await Http!.GetFromJsonAsync<List<UserDto>>("api/user");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"RefreshUsers error: {ex.Message}";
            Logger.LogError(ex, "Error refreshing users");
        }
    }
}
