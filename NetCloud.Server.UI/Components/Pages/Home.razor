@page "/"
@using Microsoft.AspNetCore.Components
@using DotNetCloud.Server.UI.Services
@inject AuthService Auth
@inject NavigationManager Nav
@inject SessionService Session

<h1>Welcome to NetCloud</h1>

@if (isLoggedIn)
{
    <p>
        <b>Logged in as @Session.Email</b>
        @if (Session.Roles.Any())
        {
            <br />
            <b>Roles:</b> @string.Join(", ", Session.Roles)
            @if (Session.IsAdministrator)
            {
                <span class="badge bg-danger ms-2">Administrator</span>
            }
        }
    </p>
    <NavLink href="/teams">Manage Teams</NavLink>
    
    @if (Session.IsAdministrator)
    {
        <NavLink href="/users" class="ms-2">User Management</NavLink>
    }

    <button class="btn btn-danger ms-2" @onclick="Logout">Logout</button>

    @if (jwtClaims != null)
    {
        <h3>JWT Claims</h3>
        <table class="table">
            <thead>
                <tr>
                    <th>Type</th>
                    <th>Value</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var claim in jwtClaims)
                {
                    <tr>
                        <td>@(claim.Key == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role" ? "role" : claim.Key)</td>
                        <td>@claim.Value</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
else
{
    <p>
        <NavLink href="/register">Register</NavLink> |
        <NavLink href="/login">Login</NavLink>
    </p>
}

<PageTitle>Home</PageTitle>

<h1>Hello, world!</h1>

Welcome to your new app.

@code {
    private bool isLoggedIn;
    private bool canUseJsInterop;
    private List<KeyValuePair<string, string>>? jwtClaims;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            canUseJsInterop = true;
            var token = await Auth.GetTokenAsync(canUseJsInterop);
            isLoggedIn = !string.IsNullOrEmpty(token);
            if (isLoggedIn && !string.IsNullOrEmpty(token))
            {
                if (string.IsNullOrEmpty(Session.Email))
                {
                    Auth.ParseAndSetSession(token, Session);
                }
                jwtClaims = Auth.GetClaimsFromToken(token);
                StateHasChanged();
            }
        }
    }

    private async Task Logout()
    {
        await Auth.LogoutAsync(canUseJsInterop);
        isLoggedIn = false;
        Session.Username = null;
        Session.Email = null;
        Session.Roles.Clear();
        jwtClaims = null;
        Nav.NavigateTo("/");
    }
}
