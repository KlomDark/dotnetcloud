<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="NetCloud.Client.Avalonia.MainWindow"
        Title="NetCloud.Client.Avalonia">
    <StackPanel Margin="20">
        <TextBlock Text="NetCloud" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        <Button Width="120" Height="40" HorizontalAlignment="Center" Click="SetupButton_Click">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Path Width="24" Height="24" Fill="Gray" Data="M12,17.27L18.18,21L16.54,13.97L22,9.24L14.81,8.63L12,2L9.19,8.63L2,9.24L7.46,13.97L5.82,21L12,17.27Z" Margin="0,0,8,0"/>
                <TextBlock Text="Setup" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
        <!-- ...other content... -->
    </StackPanel>
</Window>
